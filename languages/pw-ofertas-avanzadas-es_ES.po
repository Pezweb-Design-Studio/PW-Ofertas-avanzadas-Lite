#: src/Strategies/Lite/BulkDiscountStrategy.php:100
msgid ""
"Add each product with its own settings. The discount applies only to the "
"first X units you specify."
msgstr ""
"Añade cada producto con su configuración. El descuento solo aplica a las "
"primeras X unidades que indiques."

#: src/Strategies/Lite/BulkDiscountStrategy.php:102
msgid "Product"
msgstr "Producto"

#: src/Strategies/Lite/BulkDiscountStrategy.php:104
msgid "e.g. 15 for 15% or a fixed amount per unit."
msgstr "p. ej. 15 para un 15% o un importe fijo por unidad."

#: src/Strategies/Lite/BulkDiscountStrategy.php:105
msgid "Discounted quantity"
msgstr "Cantidad con descuento"

#: src/Strategies/Lite/BulkDiscountStrategy.php:105
msgid "Maximum units that receive the discount."
msgstr "Máximo de unidades que reciben el descuento."

#: src/Strategies/Lite/BulkDiscountStrategy.php:106
msgid "Custom badge (optional)"
msgstr "Insignia personalizada (opcional)"

#: src/Strategies/Lite/BulkDiscountStrategy.php:106
msgid "e.g. “Limited offer”, “Expiring soon”."
msgstr "p. ej. «Oferta limitada», «Caduca pronto»."

#: src/Strategies/Lite/BuyXPayYStrategy.php:61
msgid ""
"“2 for 1”, “3 for 2”, etc. The customer takes X units but pays for only Y."
msgstr ""
"«2x1», «3x2», etc. El cliente se lleva X unidades pero paga solo Y."

#: src/Strategies/Lite/BuyXPayYStrategy.php:63
msgid ""
"Very effective for fast-moving stock: consumables, overstocks, or aggressive "
"promos (e.g. 3-for-2, 2-for-1, buy 5 pay 4)."
msgstr ""
"Muy efectivo para stock que rota rápido: consumibles, excedentes o promos "
"agresivas (p. ej. 3x2, 2x1, compra 5 paga 4)."

#: src/Strategies/Lite/BuyXPayYStrategy.php:70
msgid "Buy quantity"
msgstr "Cantidad a comprar"

#: src/Strategies/Lite/BuyXPayYStrategy.php:70
msgid "Units the customer receives in each set."
msgstr "Unidades que recibe el cliente en cada conjunto."

#: src/Strategies/Lite/BuyXPayYStrategy.php:71
msgid "Pay quantity"
msgstr "Cantidad a pagar"

#: src/Strategies/Lite/BuyXPayYStrategy.php:71
msgid "Units the customer pays for in each set."
msgstr "Unidades que paga el cliente en cada conjunto."

#: src/Strategies/Lite/BuyXPayYStrategy.php:72
msgid "Maximum sets per order. Leave empty for unlimited."
msgstr ""
"Máximo de conjuntos por pedido. Déjalo vacío para ilimitado."

#: src/Strategies/Lite/ExpiryBasedStrategy.php:77
msgid "Expiry-based discount"
msgstr "Descuento por caducidad"

#: src/Strategies/Lite/ExpiryBasedStrategy.php:78
msgid "Progressive discounts for products approaching their expiry date."
msgstr ""
"Descuentos progresivos para productos próximos a su fecha de caducidad."

#: src/Strategies/Lite/ExpiryBasedStrategy.php:80
msgid ""
"Perishables, food, pharmacy. Increase the discount as the expiry date gets "
"closer."
msgstr ""
"Perecederos, alimentación, farmacia. Aumenta el descuento a medida que se "
"acerca la caducidad."

#: src/Strategies/Lite/ExpiryBasedStrategy.php:99
#: src/Strategies/Pro/TieredDiscountStrategy.php:74
msgid "Discount tiers"
msgstr "Tramos de descuento"

#: src/Strategies/Lite/ExpiryBasedStrategy.php:101
msgid ""
"Set discounts by days until expiry. Products use the best matching tier. "
"Example: 30 days → 10%, 15 days → 20%."
msgstr ""
"Define descuentos por días hasta la caducidad. Cada producto usa el mejor "
"tramo que le corresponda. Ejemplo: 30 días → 10%, 15 días → 20%."

#: src/Strategies/Lite/ExpiryBasedStrategy.php:103
msgid "Days until expiry"
msgstr "Días hasta la caducidad"

#: src/Strategies/Lite/ExpiryBasedStrategy.php:104
#: src/Strategies/Pro/TieredDiscountStrategy.php:79
msgid "Discount"
msgstr "Descuento"

#: src/Strategies/Pro/FlashSaleStrategy.php:39
msgid "Time-limited discount to create urgency."
msgstr ""
"Descuento por tiempo limitado para generar urgencia."

#: src/Strategies/Pro/FlashSaleStrategy.php:41
msgid "Peak events and launches; often strongest in 6–24 hour windows."
msgstr ""
"Picos de eventos y lanzamientos; suele funcionar mejor en ventanas de 6–24 "
"horas."

#: src/Strategies/Pro/FlashSaleStrategy.php:48
msgid "Start time"
msgstr "Hora de inicio"

#: src/Strategies/Pro/FlashSaleStrategy.php:49
msgid "End time"
msgstr "Hora de fin"

#: src/Strategies/Pro/FreeShippingStrategy.php:29
msgid "Free shipping threshold"
msgstr "Umbral de envío gratis"

#: src/Strategies/Pro/FreeShippingStrategy.php:30
msgid "Waive shipping when the cart reaches a minimum subtotal."
msgstr ""
"Gratis el envío cuando el carrito alcanza un subtotal mínimo."

#: src/Strategies/Pro/FreeShippingStrategy.php:32
msgid ""
"A strong always-on tactic; often lifts average order value by 20–35% across "
"many stores."
msgstr ""
"Táctica muy sólida de uso continuo; a menudo sube el ticket medio un 20–35% "
"en muchas tiendas."

#: src/Strategies/Pro/FreeShippingStrategy.php:41
msgid "Minimum subtotal for free shipping"
msgstr "Subtotal mínimo para envío gratis"

#: src/Strategies/Pro/FreeShippingStrategy.php:44
msgid "Amount in your store currency."
msgstr "Importe en la moneda de la tienda."

#: src/Strategies/Pro/LowStockStrategy.php:53
msgid "Low stock discount"
msgstr "Descuento por stock bajo"

#: src/Strategies/Pro/LowStockStrategy.php:54
msgid ""
"Automatically discount products when on-hand quantity falls below a "
"threshold."
msgstr ""
"Descuenta automáticamente cuando el stock disponible cae por debajo de un "
"umbral."

#: src/Strategies/Pro/LowStockStrategy.php:56
msgid ""
"Seasonal clearance, end-of-line, or when you want urgency from scarcity."
msgstr ""
"Liquidación de temporada, fin de línea o cuando quieras urgencia por "
"escasez."

#: src/Strategies/Pro/LowStockStrategy.php:63
msgid "Stock threshold"
msgstr "Umbral de stock"

#: src/Strategies/Pro/LowStockStrategy.php:63
msgid "Discount applies when stock is at or below this quantity."
msgstr ""
"El descuento aplica cuando el stock es igual o inferior a esta cantidad."

#: src/Strategies/Pro/MinAmountStrategy.php:35
msgid "Minimum order discount"
msgstr "Descuento por pedido mínimo"

#: src/Strategies/Pro/MinAmountStrategy.php:36
msgid "Apply a discount when the cart subtotal reaches a minimum amount."
msgstr ""
"Aplica un descuento cuando el subtotal del carrito alcanza un importe "
"mínimo."

#: src/Strategies/Pro/MinAmountStrategy.php:38
msgid ""
"Works year-round to lift average order value. Especially strong before "
"holidays and peak sales periods."
msgstr ""
"Funciona todo el año para subir el ticket medio. Especialmente potente antes "
"de festividades y picos de venta."

#: src/Strategies/Pro/RecurringPurchaseStrategy.php:95
msgid "Repeat purchase reward"
msgstr "Recompensa por recompra"

#: src/Strategies/Pro/RecurringPurchaseStrategy.php:96
msgid "Reward customers who have bought the same product multiple times."
msgstr ""
"Premia a clientes que han comprado el mismo producto varias veces."

#: src/Strategies/Pro/RecurringPurchaseStrategy.php:98
msgid ""
"Consumables, supplements, cosmetics—any repurchase SKU. Often improves "
"retention for subscribe-and-save style catalogs."
msgstr ""
"Consumibles, suplementos, cosmética—cualquier SKU de recompra. Suele mejorar "
"la retención en catálogos tipo suscripción."

#: src/Strategies/Pro/RecurringPurchaseStrategy.php:105
msgid "Prior purchases required"
msgstr "Compras previas necesarias"

#: src/Strategies/Pro/RecurringPurchaseStrategy.php:105
msgid "How many completed purchases of the product unlock the discount."
msgstr ""
"Cuántas compras completadas del producto desbloquean el descuento."

#: src/Strategies/Pro/TieredDiscountStrategy.php:55
msgid "Tiered quantity discount"
msgstr "Descuento por tramos de cantidad"

#: src/Strategies/Pro/TieredDiscountStrategy.php:56
msgid "Higher discounts as the number of items in the cart increases."
msgstr ""
"Mayores descuentos a medida que aumentan los artículos en el carrito."

#: src/Strategies/Pro/TieredDiscountStrategy.php:58
msgid ""
"Peak sales and volume campaigns. Strong with low unit-cost items. Example: "
"10% at 3 items, 20% at 5, 30% at 10."
msgstr ""
"Picos de venta y campañas por volumen. Muy fuerte con productos de bajo coste "
"unitario. Ejemplo: 10% con 3 artículos, 20% con 5, 30% con 10."

#: src/Strategies/Pro/TieredDiscountStrategy.php:76
msgid "Define tiers; the best matching tier is applied."
msgstr ""
"Define tramos; se aplica el mejor tramo que corresponda."

#: src/Strategies/Pro/TieredDiscountStrategy.php:78
msgid "Item quantity"
msgstr "Cantidad de artículos"

#: src/Strategies/Pro/TieredDiscountStrategy.php:79
msgid "Percentage or fixed value, depending on discount type."
msgstr ""
"Porcentaje o valor fijo, según el tipo de descuento."

#: src/Admin/Views/wizard.lite.php
msgid ""
"Global stacking rules and advanced options are available in Pro (%1$sview "
"Pro edition%2$s)."
msgstr ""
"Las reglas globales de apilamiento y opciones avanzadas están disponibles en "
"Pro (%1$sver la edición Pro%2$s)."
